PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/safemexc
FRONTEND_URL=http://localhost:5173

# USDⓈ-M futures (FAPI) + optional algo (SAPI) — same key; enable Futures on the key
BINANCE_API_KEY=
BINANCE_API_SECRET=
# Optional signer mode: HMAC (default) or ED25519
# BINANCE_SIGNATURE_TYPE=HMAC
# For ED25519, set BINANCE_SIGNATURE_TYPE=ED25519 and provide PEM private key.
# You can set BINANCE_PRIVATE_KEY directly (supports \n escaped newlines), or place the PEM/base64 key in BINANCE_API_SECRET.
# BINANCE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# Optional overrides (defaults: https://fapi.binance.com, https://api.binance.com)
# BINANCE_FAPI_BASE_URL=https://fapi.binance.com
# BINANCE_SAPI_BASE_URL=https://api.binance.com
